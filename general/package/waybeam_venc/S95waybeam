#!/bin/sh

case "$1" in
  start)
    echo "Stopping majestic to free camera pipeline..."
    killall -9 majestic 2>/dev/null

    echo "Loading rtl88x2cu Wi-Fi driver..."
    modprobe 88x2cu 2>/dev/null

    echo "Starting waybeam_venc..."
    start-stop-daemon -S -q -m -p /var/run/waybeam_venc.pid -b -x /usr/bin/waybeam_venc
    ;;
  stop)
    echo "Stopping waybeam_venc..."
    start-stop-daemon -K -q -p /var/run/waybeam_venc.pid
    ;;
  restart|reload)
    $0 stop
    sleep 1
    $0 start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac
exit 0
